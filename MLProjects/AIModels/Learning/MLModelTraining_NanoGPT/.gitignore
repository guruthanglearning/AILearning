# .NET Build Artifacts
bin/
obj/
publish/
*.dll
*.exe
*.pdb

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
.vscode/settings.json

# Model Checkpoints (DON'T CHECK IN)
checkpoints/
*.bin
*.pth
*.pt
*.ckpt
*.safetensors

# Training Data (DON'T CHECK IN)
data/shakespeare.txt
data/shakespeare_train.txt
data/shakespeare_val.txt
data/*.txt
data/*.csv
data/*.json

# Keep data folder structure but ignore content
!data/.gitkeep

# Logs (DON'T CHECK IN)
logs/
*.log
*.txt.log

# Reports and temporary files
reports/
*.tmp
*.temp
*.bak
*.backup

# Docker volumes and runtime
.docker/
volumes/

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini

# Python virtual environments (if any)
venv/
env/
.env
__pycache__/
*.pyc

# Node modules (if any)
node_modules/

# Test results
TestResults/
*.trx
*.coverage

# NuGet packages
*.nupkg
packages/
!packages/repositories.config

# Monitoring data
monitoring/data/
prometheus_data/
grafana_data/

# IDE files
.idea/
*.swp
*.swo
*~

# Build outputs
[Bb]uild/
[Ll]og/

# Keep empty directories with .gitkeep
!**/.gitkeep
