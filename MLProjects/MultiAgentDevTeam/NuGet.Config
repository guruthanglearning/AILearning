<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- Store all NuGet packages in the shared environment to avoid duplication across projects -->
    <add key="globalPackagesFolder" value="D:\Study\AILearning\shared_Environment\.nuget\packages" />
  </config>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
