# ── Stage 1: Build React app ──────────────────────────────────────────────────
FROM node:22-alpine AS build
WORKDIR /app

# Install dependencies first for better layer caching
COPY src/MultiAgentDevTeam.UI/package*.json ./
RUN npm ci

# Copy source and build
COPY src/MultiAgentDevTeam.UI/ ./
RUN npm run build

# ── Stage 2: Serve with nginx ─────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# Copy built React app
COPY --from=build /app/dist /usr/share/nginx/html

# Copy nginx config template — the official nginx image runs envsubst on
# /etc/nginx/templates/*.template and writes results to /etc/nginx/conf.d/
COPY docker/nginx.conf.template /etc/nginx/templates/default.conf.template

# Default API upstream — override in docker-compose or K8s deployment env vars
ENV API_HOST=orchestrator
ENV API_PORT=5000

EXPOSE 80
