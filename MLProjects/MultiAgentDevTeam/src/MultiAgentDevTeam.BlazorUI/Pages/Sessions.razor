@page "/sessions"
@rendermode InteractiveServer
@inject ISessionApiClient SessionClient

<PageTitle>Past Sessions</PageTitle>

<h1>Past Sessions</h1>

@if (_loading)
{
    <p>Loading sessions...</p>
}
else if (_sessions.Count == 0)
{
    <p id="no-sessions">No sessions found. <a href="/">Start your first pipeline!</a></p>
}
else
{
    <table class="sessions-table" id="sessions-table">
        <thead>
            <tr>
                <th>Session ID</th>
                <th>Requirement</th>
                <th>Status</th>
                <th>Artifacts</th>
                <th>Duration</th>
                <th>Started</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in _sessions)
            {
                <tr>
                    <td><a href="/sessions/@s.SessionId">@s.SessionId.ToString()[..8]…</a></td>
                    <td>@s.Requirement</td>
                    <td>
                        <span class="badge @(s.Success ? "badge-success" : "badge-danger")">
                            @(s.Success ? "✅ Success" : "❌ Failed")
                        </span>
                    </td>
                    <td>@s.ArtifactCount</td>
                    <td>@s.TotalDuration</td>
                    <td>@s.StartedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
