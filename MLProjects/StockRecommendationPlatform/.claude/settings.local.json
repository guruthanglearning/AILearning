{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(git push *)",
      "Read(.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(*.db)",
      "Read(*.sqlite)",
      "Read(*.sqlite3)",
      "Read(*secret*)",
      "Read(*credential*)",
      "Read(*password*)",
      "Read(*cookie*)",
      "Read(*token*)",
      "Bash(cat .env*)",
      "Bash(type .env*)"
    ],
    "deny": [
      "Bash(*AppData*Chrome*Cookies*)",
      "Bash(*AppData*Firefox*places.sqlite*)",
      "Bash(*AppData*Microsoft*Credentials*)",
      "Bash(*AppData*Microsoft*Vault*)"
    ]
  }
}
