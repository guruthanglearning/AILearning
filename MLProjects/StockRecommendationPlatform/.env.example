# .env.example — copy to .env and fill in secrets; never commit .env

# Postgres (matches docker-compose defaults for local dev)
DATABASE_URL=postgresql+asyncpg://rec:rec@localhost:5433/recommendation

# Redis
REDIS_URL=redis://localhost:6380/0
USE_REDIS=false

# Polygon.io API key (Phase 0b) — leave blank to use yfinance fallback
POLYGON_API_KEY=

# Optional external ML sentiment service
STOCK_PREDICTION_API_URL=

# Tuning
QUOTE_STALE_SECONDS=120
AGENT_TIMEOUT_SECONDS=45
