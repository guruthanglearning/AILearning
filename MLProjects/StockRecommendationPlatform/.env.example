# .env.example — copy to .env and fill in your secrets; NEVER commit .env
# All keys below are required unless marked optional.

# ── AI ─────────────────────────────────────────────────────────────────────
# Anthropic API key — get at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Market Data ────────────────────────────────────────────────────────────
# Polygon.io API key — leave blank to fall back to yfinance (delayed data)
POLYGON_API_KEY=

# Finnhub API key for news sentiment — get free key at finnhub.io (optional)
FINNHUB_API_KEY=

# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL (matches docker-compose defaults for local dev)
DATABASE_URL=postgresql+asyncpg://rec:rec@localhost:5433/recommendation

# ── Cache (optional) ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0
USE_REDIS=false

# ── Tuning ─────────────────────────────────────────────────────────────────
QUOTE_STALE_SECONDS=120
AGENT_TIMEOUT_SECONDS=45
