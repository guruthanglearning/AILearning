# Copy this file to secret.yaml and fill in real values.
# secret.yaml is gitignored — never commit actual keys.
apiVersion: v1
kind: Secret
metadata:
  name: stockresearch-secret
  namespace: stockresearch
type: Opaque
stringData:
  # Postgres credentials (must match postgres StatefulSet env)
  POSTGRES_PASSWORD: "rec"
  DATABASE_URL: "postgresql+asyncpg://rec:rec@postgres-svc:5432/recommendation"

  # External API keys
  ANTHROPIC_API_KEY: "sk-ant-api03-..."
  POLYGON_API_KEY: ""
  FINNHUB_API_KEY: ""
